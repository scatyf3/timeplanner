# 复制成 .env 填好。所有机密都在这里，不进 git。

# Obsidian 库根目录（只读数据源）
TIMEPLANNER_VAULT="/Users/juanitahowe/Documents/GitHub/SCAT's HOME"
# 日记相对路径模板：{year}/{month} 会被替换，文件名固定 {date}.md
TIMEPLANNER_DAILY_GLOB="0. PeriodicNotes/{year}/Daily/{month}"

# ActivityWatch 本地 REST
AW_HOST="http://localhost:5600"
# 跨机 AW 同步（可选）：一个被 Syncthing/WebDAV 镜像的共享文件夹，存各机每日观测快照
# <host>-<date>.json。留空=单机，不启用。汇集端读它 + 本机实时 AW 合并出③观测线。
# 各机跑 `timeplanner aw-export`（或 scripts/aw_export.py）往这里写自己的快照。
TIMEPLANNER_AW_SYNC_DIR=""

# 天气（Open-Meteo，免 key）。默认纽约。
TIMEPLANNER_LAT="40.7291"
TIMEPLANNER_LON="-73.9965"
TIMEPLANNER_TIMEZONE="America/New_York"

# Google Calendar（M3 才需要）
# 从 Google Cloud Console 下载 OAuth 客户端 json，路径填这里
GCAL_CREDENTIALS="credentials.json"
GCAL_TOKEN="token.json"
# 两个独立日历的 ID（在 GCal 设置里找，或用 API 建）
GCAL_PLAN_ID=""
GCAL_ACTUAL_ID=""
# 订阅日历（同账号）：逗号分隔的日历 ID，只读，当外部固定约束（🔒），planner 只在其空隙排块。
# 用 `timeplanner calendars` 列出账号里所有日历的 ID 再往这里填。
TIMEPLANNER_GCAL_REFS=""

# 存储后端：local（本地 data/*.json）| gcal（真日历，需上面配好）
TIMEPLANNER_BACKEND="local"

# Cubox 读取 API（按 tag 读文章/高亮）。key 在 https://cubox.cc/my/settings/extensions
TIMEPLANNER_CUBOX_KEY=""
# 国际版用 cubox.pro；国内 cubox.cc
TIMEPLANNER_CUBOX_DOMAIN="cubox.cc"
# 定期同步到本地、供 agent 搜索/复盘的文件夹（逗号分隔），跑 `timeplanner cubox --sync`
TIMEPLANNER_CUBOX_FOLDERS="科学学习,科学工作,health,心理"

# Telegram（Phase 1 才需要）
TG_BOT_TOKEN=""
TG_CHAT_ID=""
